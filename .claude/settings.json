{
  "permissions": {
    "allow": ["Edit", "Write"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash setup-dev.sh 2>&1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/hooks/doc-check.txt"
          },
          {
            "type": "command",
            "command": "cat .claude/hooks/commit-reminder.txt"
          }
        ]
      }
    ]
  }
}
