From 6656ae7e0f4710031e7a96a99eece08506f177f7 Mon Sep 17 00:00:00 2001
From: Maurice Hieronymus <mhi@mailbox.org>
Date: Fri, 25 Jul 2025 17:14:45 +0200
Subject: [PATCH] gcc: Add support for sentientos

---
 config.sub                  |  2 +-
 fixincludes/mkfixinc.sh     |  2 ++
 gcc/config.gcc              | 10 ++++++++++
 gcc/config/sentientos.h     | 33 +++++++++++++++++++++++++++++++++
 libgcc/config.host          |  4 ++++
 libstdc++-v3/crossconfig.m4 |  6 ++++++
 6 files changed, 56 insertions(+), 1 deletion(-)
 create mode 100644 gcc/config/sentientos.h

diff --git a/config.sub b/config.sub
index 38f3d037a..1efc93a2a 100755
--- a/config.sub
+++ b/config.sub
@@ -1749,7 +1749,7 @@ case $os in
 	     | onefs* | tirtos* | phoenix* | fuchsia* | redox* | bme* \
 	     | midnightbsd* | amdhsa* | unleashed* | emscripten* | wasi* \
 	     | nsk* | powerunix* | genode* | zvmoe* | qnx* | emx* | zephyr* \
-	     | fiwix* )
+	     | fiwix* | sentientos* )
 		;;
 	# This one is extra strict with allowed versions
 	sco3.2v2 | sco3.2v[4-9]* | sco5v6*)
diff --git a/fixincludes/mkfixinc.sh b/fixincludes/mkfixinc.sh
index 7112f4dcd..0e176e1d1 100755
--- a/fixincludes/mkfixinc.sh
+++ b/fixincludes/mkfixinc.sh
@@ -18,6 +18,8 @@ case $machine in
     powerpc-*-rtems*   | \
     powerpcle-*-eabisim* | \
     powerpcle-*-eabi* | \
+    *-sentientos* | \
+    *-*-sentientos* | \
     *-*-vxworks7* | \
     *-musl* )
 	#  IF there is no include fixing,
diff --git a/gcc/config.gcc b/gcc/config.gcc
index 40b50dc96..b9339623a 100644
--- a/gcc/config.gcc
+++ b/gcc/config.gcc
@@ -723,6 +723,13 @@ x86_cpus="generic intel"
 
 # Common parts for widely ported systems.
 case ${target} in
+*-*-sentientos*)
+	extra_options="$extra_options gnu-user.opt"
+	gas=yes
+	gnu_ld=yes
+	default_use_cxa_atexit=yes
+	use_gcc_stdint=provide
+	;;
 *-*-darwin*)
   tmake_file="t-darwin "
   tm_file="${tm_file} darwin.h"
@@ -2583,6 +2590,9 @@ riscv*-*-freebsd*)
 	gcc_cv_initfini_array=yes
 	with_tls=${with_tls:-trad}
 	;;
+riscv*-*-sentientos*)
+	tm_file="${tm_file} elfos.h glibc-stdint.h sentientos.h"
+	;;
 
 loongarch*-*-linux*)
 	tm_file="elfos.h gnu-user.h linux.h linux-android.h glibc-stdint.h ${tm_file}"
diff --git a/gcc/config/sentientos.h b/gcc/config/sentientos.h
new file mode 100644
index 000000000..e343fdbad
--- /dev/null
+++ b/gcc/config/sentientos.h
@@ -0,0 +1,33 @@
+/* Useful if you wish to make target-specific GCC changes. */
+#undef TARGET_SENTIENTOS
+#define TARGET_SENTIENTOS 1
+
+/* Default arguments you want when running your
+   i686-myos-gcc/x86_64-myos-gcc toolchain */
+#undef LIB_SPEC
+#define LIB_SPEC "-lc -lg -lm -luserspace" /* link against C standard library  \
+                                            */
+
+/* Files that are linked before user code.
+   The %s tells GCC to look for these files in the library directory. */
+#undef STARTFILE_SPEC
+#define STARTFILE_SPEC "crt0.o%s"
+
+/* Tell ld to force 4KB pages*/
+#undef LINK_SPEC
+#define LINK_SPEC "-z max-page-size=4096"
+
+/* Files that are linked after user code. */
+#undef ENDFILE_SPEC
+#define ENDFILE_SPEC ""
+
+/* Additional predefined macros. */
+#undef TARGET_OS_CPP_BUILTINS
+#define TARGET_OS_CPP_BUILTINS()                                               \
+  do {                                                                         \
+    builtin_define("__sentientos__");                                          \
+    builtin_define("__unix__");                                                \
+    builtin_assert("system=sentientos");                                       \
+    builtin_assert("system=unix");                                             \
+    builtin_assert("system=posix");                                            \
+  } while (0);
diff --git a/libgcc/config.host b/libgcc/config.host
index 6a88ee5a2..e6ad23bb1 100644
--- a/libgcc/config.host
+++ b/libgcc/config.host
@@ -1358,6 +1358,10 @@ riscv*-*-freebsd*)
 	tmake_file="${tmake_file} riscv/t-crtstuff riscv/t-softfp${host_address} t-softfp riscv/t-elf riscv/t-elf${host_address} t-slibgcc-libgcc"
 	extra_parts="$extra_parts crtbegin.o crtend.o crti.o crtn.o crtendS.o crtbeginT.o"
 	;;
+riscv*-*-sentientos*)
+	tmake_file="${tmake_file} riscv/t-softfp${host_address} t-softfp riscv/t-elf riscv/t-elf${host_address}"
+	extra_parts="$extra_parts crtbegin.o crtend.o crti.o crtn.o"
+	;;
 riscv*-*-*)
 	tmake_file="${tmake_file} riscv/t-softfp${host_address} t-softfp riscv/t-elf riscv/t-elf${host_address}"
 	extra_parts="$extra_parts crtbegin.o crtend.o crti.o crtn.o"
diff --git a/libstdc++-v3/crossconfig.m4 b/libstdc++-v3/crossconfig.m4
index b3269cb88..85b886834 100644
--- a/libstdc++-v3/crossconfig.m4
+++ b/libstdc++-v3/crossconfig.m4
@@ -263,6 +263,12 @@ case "${host}" in
     GLIBCXX_CHECK_MATH_SUPPORT
     GLIBCXX_CHECK_STDLIB_SUPPORT
     ;;
+  *-sentientos*)
+    GLIBCXX_CHECK_COMPILER_FEATURES
+    GLIBCXX_CHECK_LINKER_FEATURES
+    GLIBCXX_CHECK_MATH_SUPPORT
+    GLIBCXX_CHECK_STDLIB_SUPPORT
+    ;;
   *-vxworks*)
     AC_DEFINE(HAVE_ACOSF)
     AC_DEFINE(HAVE_ASINF)
-- 
2.49.0

